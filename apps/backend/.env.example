# Copy to .env in this directory (apps/backend/.env)

# OpenAI — chat + Whisper (speech-to-text)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs — text-to-speech
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_VOICE_ID=
ELEVEN_LABS_MODEL_ID=eleven_multilingual_v2

# Optional: absolute path to ffmpeg if it is not on PATH
# FFMPEG_PATH=
# RHUBARB_FFMPEG_PATH=
